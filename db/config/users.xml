<clickhouse>
    <users>
        <!-- Configure default user with environment-configured password and unrestricted network access -->
        <default>
            <password from_env="CLICKHOUSE_PASSWORD" />
            <networks>
                <ip>::/0</ip>
            </networks>
            <profile>default</profile>
            <quota>default</quota>
            <access_management>1</access_management>
        </default>
    </users>
</clickhouse>
