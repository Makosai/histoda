# ClickHouse Database Connection Settings
# Copy this file to .env and adjust values for your environment.

# Database username (defaults to 'default')
CLICKHOUSE_USER=default

# Database password (defaults to empty)
CLICKHOUSE_PASSWORD=

# DNS resolution order for Node.js client: 'ipv4first' (default, recommended inside Docker Compose) or 'verbatim' (default Node.js behavior / IPv6 first)
DNS_RESOLUTION_ORDER=ipv4first
